public class FileDemo03 {

	//Writing the product objects p in the file (binary)
	//Product(Obje) --> DataOutputStream --> FileOutputStream --> .bin Stored
	public static void main1(String[] args) {
		
		Product p=new Product(12,"Iphone 16ProMax",70000);
		

		String path="F:/Java Workshop/Day_16/product12.bin";
	
	
		try(FileOutputStream fout=new FileOutputStream(path)){
			try(DataOutputStream dout=new DataOutputStream(fout)){
				dout.writeInt(p.getId());
				dout.writeUTF(p.getName());
				dout.writeDouble(p.getPrice());
			}
		}
		catch(Exception e) {
			e.printStackTrace();
		}
	}
	
	// Display Data In Binaryfile  ;  .bin file --> FileInputStream --> DataInputStream --> Product Info Display
	public static void main2(String[] args) {
		
		String path="F:/Java Workshop/Day_16/product12.bin";
		
		try(FileInputStream fin=new FileInputStream(path)){
			try(DataInputStream din=new DataInputStream(fin)){
				int id=din.readInt();
				String name=din.readUTF();
				double price=din.readDouble();
				Product p=new Product(id,name,price);
				System.out.println("File Read :"+p);
			}
		}
		catch(Exception e) {
			e.printStackTrace();
		}
		
	}
	
