package com.dkte.service;

import com.dkte.entities.Employee;

public class EmpService {

	Employee[] employees;
	int count;
	
	public EmpService(int size) {
		employees=new Employee[size];
		count=0;
	}
	
	public boolean addEmployee(Employee emp) {
		if(count<employees.length) {
			employees[count++]=emp;
			return true;
		}
		return false;
	}
	
	public void displayAll() {
	 for(int i=0;i<count;i++) {
		 System.out.println(employees[i]);
	   }
	}
		
	 public Employee searchById(int id) {
	        for (int i = 0; i < count; i++) {
	            if (employees[i].getEmpid() == id)
	                return employees[i];
	        }
	        return null;
	    }
		
	public void displayByJoiYear(int year) {
	
		for(int i=0;i<count;i++) {
			if(year==employees[i].getDoj().getYear()) {
				System.out.println(employees[i]);
			}
		}
	}
	
	public Employee findMaxSalary() {
	Employee max=employees[0];
	if(count==0) {
		return null;
	}
	for(int i=0;i<count;i++) {
		if(max.getSalary()<employees[i].getSalary()) {
			max=employees[i];
		}
	 }
	return max;
	}
		
		
		
		
		
		
		
		
	}

}
