package com.dkte.test;

public class person {
	String name;
	Date dob;
	
	public person() {
		
	}
	
	public person(String name,int day,int month,int year) {
		this.name = name;
		this.dob =new Date(day,month,year);
	}

	public String getName() {
		return name;
	}

	public void setName(String name) {
		this.name = name;
	}

	public Date getDob() {
		return dob;
	}

	public void setDob(Date dob) {
		this.dob = dob;
	}
	
	
	
}
