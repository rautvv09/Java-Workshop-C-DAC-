package com.sunbeam;

import java.util.Scanner;

class Employee {
	private int empid;
	private String name;
	private double salary;

	// paramaterless ctor
	public Employee() {
		System.out.println("Employee Parametrless Ctor");
		this.name = "";
		this.salary = 100;
	}

	// paramaterized ctor
	public Employee(int empid, String name, double salary) {
		System.out.println("Employee Paramaterized Ctor");
		this.empid = empid;
		this.name = name;
		this.salary = salary;
	}

	// setters
	public void setEmpid(int empid) {
		if (empid < 0)
			return;
		this.empid = empid;
	}

	// getters
	public int getEmpid() {
		return empid;
	}

	// TO-DO
	// Implement teh setters and getters for the name and salary
	// also provide the acceptEmployee()

	public String getName() {
		return name;
	}

	public void setName(String name) {
		this.name = name;
	}

	public double getSalary() {
		return salary;
	}

	public void setSalary(double salary) {
		this.salary = salary;
	}

	// Facilitators
	public void displayEmployee() {
		System.out.println("Empid -" + this.empid);
		System.out.println("Name -" + name);
		System.out.println("Salary -" + salary);
	}
	
	public void accpetEmp(Scanner sc){
		System.out.println("Enter Empid -" );
		empid=sc.nextInt();
		
		System.out.println("Enter Name -");
		name=sc.nextLine();
		
		
		System.out.println("Enter Salary -" );
		salary=sc.nextDouble();
	}

}

public class Program {

	public static void main(String[] args) {
		
		Scanner sc=new Scanner(System.in);
		
		Employee e1 = new Employee();
		Employee e2 = new Employee(2, "Mukesh", 10000);
		Employee e3=new Employee();
		e3.accpetEmp(sc);
		e1.displayEmployee();
		e2.displayEmployee();
		e3.displayEmployee();
		// e1.empid = 1;
		e1.setEmpid(1);

//		System.out.println("e1.empid - " + e1.empid);
		System.out.println("e1.empid - " + e1.getEmpid());

	}

}
