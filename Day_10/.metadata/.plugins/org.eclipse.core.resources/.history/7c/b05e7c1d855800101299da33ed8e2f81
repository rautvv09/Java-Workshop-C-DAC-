package com.dkte.p5;

import java.util.Date;

class Box<T>{
	
	private T obj;

	public T getObj() {
		return obj;
	}

	public void setObj(T obj) {
		this.obj = obj;
	}

	public Box(T obj) {
		this.obj = obj;
	}

	public Box() {
	
	}
	
	
}
public class Program01 {

	public static void displayBox(Box< ? super Integer> b) {
			
		System.out.println("Values :"+b.getObj());

	}

	public static void main(String[] args) {
		
		Box<Integer> b1=new Box<Integer>(45);
		displayBox(b1);
		
		Box<Double> b2=new Box<Double>(45.5);
		displayBox(b2);//not Ok Because display function support only the super class datatype of the Integer

		Box<Date> b3=new Box<Date>(new Date());
		displayBox(b3);//not Ok Because display function support only the super class datatype of the Integer
	}

}
