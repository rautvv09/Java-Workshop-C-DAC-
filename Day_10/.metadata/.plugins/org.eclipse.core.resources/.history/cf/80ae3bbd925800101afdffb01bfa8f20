package com.dkte.p1;

public class Program01 {
	public static <T> void display(T[] b) {
		for(T ele:b) {
			System.out.println("Element :"+ele);
			
		}
	}

	public static void main(String[] args) {
		

		Integer[] arr= {10,20,30,40,50,60};
		display(arr);
		
		Double[] arr2= {10.2,23.3,22.3,56.0,34.2,52.8};
		display(arr2);
		
		String[] arr3= { "Anil","Sunil","Patil","Amit","Anay","Vinay","Ritesh","Faruk","Priti","Riya"};
		display(arr3);
		
	}

}
