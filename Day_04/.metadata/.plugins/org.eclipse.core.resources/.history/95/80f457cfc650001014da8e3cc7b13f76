package com.dkte;

class Student{
	String name;
	int rollno;
	double marks;
	
	public Student() {
		
	}
	
	public Student(String name,int rollno,double marks) {
		this.name=name;
		this.rollno=rollno;
		this.marks=marks;
	}
	
	public void displayStudent() {
		System.out.println("Student Name:"+name);
		System.out.println("Student Roll No:"+rollno);
		System.out.println("Student Marks:"+marks);
	}
}
