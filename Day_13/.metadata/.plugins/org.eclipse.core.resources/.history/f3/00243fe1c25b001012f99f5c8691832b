package com.dkte;

package com.sunbeam;

import java.util.Collection;
import java.util.LinkedHashMap;
import java.util.Map;
import java.util.Set;

public class Program02 {

	public static void main(String[] args) {
		Map<Integer, String> m1 = new LinkedHashMap<>();
		m1.put(143, "Ramesh");
		m1.put(121, "Anil");
		m1.put(132, "Mukesh");
		m1.put(154, "Suresh");
		m1.put(166, "Ram");
		// m1.put(166, "Ram"); // Duplicate keys are not allowed
		// m1.put(166, "Sham"); // If keys are duplicated it will replace the value
		m1.put(null, "Sham"); // null key is allowed
		m1.put(null, "Ram"); // Duplicate keys are not allowed however
		// duplicate values are allowed
		m1.put(178, null);
		m1.put(189, null);

		System.out.println("size of m1 - " + m1.size());

		Set<Integer> keys = m1.keySet();
		System.out.println("Keys ->");
		for (Integer k : keys)
			System.out.println(k);

		System.out.println("Values ->");
		Collection<String> values = m1.values();
		for (String v : values)
			System.out.println(v);
	}

}
