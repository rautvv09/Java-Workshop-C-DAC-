package com.dkte;

class InvalidDateException extends RuntimeException {

	public InvalidDateException() {
	}

	public InvalidDateException(String message) {
		super(message);
	}
}
class Date{
	private int day;
	private int month;
	
	public int getDay() {
		return day;
	}
	
	public void setDay(int day) {
		if(day>31 || day<1) {
			throw new InvalidDateEception();
		}
		this.day = day;
	}
	
	public int getMonth() {
		return month;
	}
	
	public void setMonth(int month) {
		if(month>12 ||month<1) {
			throw new InvalidDateException("Month Should Be In Between 1 to 12")
		}
		this.month = month;
	}
	
	@Override
	public String toString() {
		return "Date [day=" + day + ", month=" + month + "]";
	}
	
	
}
public class Program01 {

	public static void main(String[] args) {
		
		Date d1=new Date();
		d1.setDay(5);
		d1.setMonth(8);
		d1.toString();
	}

}
