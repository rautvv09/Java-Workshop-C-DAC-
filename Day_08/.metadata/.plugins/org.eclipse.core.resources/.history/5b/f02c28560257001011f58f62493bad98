package com.dkte;

class Date{
	private int day;
	private int month;
	
	public int getDay() {
		return day;
	}
	public void setDay(int day) {
		this.day = day;
	}
	public int getMonth() {
		return month;
	}
	public void setMonth(int month) {
		this.month = month;
	}
	
	@Override
	public String toString() {
		return "Date [day=" + day + ", month=" + month + "]";
	}
	
	
}
