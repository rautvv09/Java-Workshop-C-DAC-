package com.dkte;

import java.awt.event.ActionListener;

import javax.swing.JButton;
import javax.swing.JFrame;
import javax.swing.JOptionPane;

public class Window extends JFrame{

	private JButton showDialogButton;
	
	public Window() {
		this.setTitle("My Window");
		this.setSize(800,600);
		this.setDefaultCloseOperation(DISPOSE_ON_CLOSE);
		this.setLayout(null);
		
		showDialogButton =new JButton();
		showDialogButton.setBounds(300,200,100,30);
		this.add(showDialogButton);
		
		showDialogButton.addActionListener((e)->{
			EssayDialog essayDialog=new EssayDialog();
			essayDialog.setModl(true);
			essayDialog.setVisible(true);
			
			String message="Title :"+essayDialog.getTitle()+"\nEssay :"+essayDialog.getEssay();
			JOptionPane.showMessageDialog(this, message)
		});
		
	}
}
