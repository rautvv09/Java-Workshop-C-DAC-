package com.dkte;

import java.util.Objects;
import java.util.PriorityQueue;
import java.util.Queue;

class Product implements Comparable<Product>{
	int id;
	double price;
	String name;
	
	@Override
	public int compareTo(Product o) {
		// TODO Auto-generated method stub
		return this.id-o.id;
	}

	public int getId() {
		return id;
	}

	public void setId(int id) {
		this.id = id;
	}

	public double getPrice() {
		return price;
	}

	public void setPrice(double price) {
		this.price = price;
	}

	public String getName() {
		return name;
	}

	public void setName(String name) {
		this.name = name;
	}

	@Override
	public boolean equals(Object obj) {
		if (this == obj)
			return true;
		if (!(obj instanceof Product))
			return false;
		Product other = (Product) obj;
		return id == other.id && Objects.equals(name, other.name)
				&& Double.doubleToLongBits(price) == Double.doubleToLongBits(other.price);
	}

	@Override
	public String toString() {
		return "Product [id=" + id + ", price=" + price + ", name=" + name + "]";
	}

	public Product(int id, double price, String name) {
		this.id = id;
		this.price = price;
		this.name = name;
	}

	public Product() {
		
	}
	
	
}
public class Program03 {

	public static void main(String[] args) {
		
		Queue<Product> products=new PriorityQueue<Product>();
		
	
		products.add(new Product(12,90,"Pen"));
		products.add(new Product(22,880,"Book"));
		products.add(new Product(88,880,"Pencil"));
		products.add(new Product(4,  50,"Book"));
		products.add(new Product(1, 8 ,"Eraser"));
		products.add(new Product(3,  12,"Ruler"));

		
		System.out.println("Peek Element:"+products.peek());

	}

}
