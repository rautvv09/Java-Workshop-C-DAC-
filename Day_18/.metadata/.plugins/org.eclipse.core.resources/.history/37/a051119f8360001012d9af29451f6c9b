package com.dkte;

public class Album {
    private int albumId;
    private String title;

    public Album(int albumId, String title) {
        this.albumId = albumId;
        this.title = title;
    }

    public int getAlbumId() {
        return albumId;
    }

    public String getTitle() {
        return title;
    }

    public String toString() {
        return "Album ID: " + albumId + ", Title: " + title;
    }
}

