	    public static void addArtist(Scanner sc) {
	        System.out.print("Artist ID: ");
	        int id = sc.nextInt();
	        
	        System.out.print("Artist Name: ");
	        sc.nextLine();
	        String name = sc.nextLine();
	        
	        
	        try (Connection con = DbUtil.getConnection()) {
	        	String sql1 = "select * from artist where artist_id = ?";
	            try (PreparedStatement ps = con.prepareStatement(sql1)) {
	                ps.setInt(1, id);
	                ResultSet rs = ps.executeQuery();
	                if(rs.next()) {
	                	System.out.println("Artist id already exist..... Please try with different id.");
	                	return;
	                }
	                
	            }
	            
	            String sql = "INSERT INTO Artist (artist_id, name) VALUES (?, ?)";
	            try (PreparedStatement ps = con.prepareStatement(sql)) {
	                ps.setInt(1, id);
	                ps.setString(2, name);
	                int rows = ps.executeUpdate();
	                System.out.println("Artist added: " + rows);
	            }
	        } catch (Exception e) {
	            e.printStackTrace();
	        }
	    }
	    
	    
